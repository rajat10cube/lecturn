# Copy to .env for local dev.  All vars are prefixed LECTURN_.

# Storage
LECTURN_DATA_DIR=./data

# Libraries: either point at a YAML config...
# LECTURN_CONFIG=../lecturn.yaml
# ...or use a single-root fallback:
# LECTURN_COURSES_DIR=D:/udemy-downloads

# Scanning
LECTURN_SCAN_ON_START=true
LECTURN_SECTION_MAX_DEPTH=2

# Media
LECTURN_FFMPEG=auto
LECTURN_TRANSCODE=on-demand

# Auth (single shared credential)
LECTURN_AUTH=basic
LECTURN_AUTH_USER=admin
LECTURN_AUTH_PASS=change-me

# Dev
LECTURN_DEV_CORS=true
